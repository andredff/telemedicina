# Configuração para Supabase Local (Docker)
# Copie este arquivo para .env.local e ajuste se necessário

# Supabase Local URLs
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Cielo Payment Server (used by cielo-server.js, NOT by the frontend)
# Get credentials from Cielo dashboard or sandbox registration.
CIELO_MERCHANT_ID=
CIELO_MERCHANT_KEY=
CIELO_SANDBOX=true

# Supabase server-side (used by cielo-server.js for payment logging)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# E-mail operacional da logística (fallback caso o admin não configure
# Notificações > Email de Notificações)
LOGISTICS_NOTIFICATION_EMAIL=

# Correios API Rastro (fallback do servidor caso o admin não configure no painel).
# Enquanto não estiver configurada, o sistema valida e salva o código como pendente.
CORREIOS_API_BASE_URL=https://api.correios.com.br
CORREIOS_API_TOKEN=
# Alternativa ao token fixo: gerar token via usuário/senha + cartão de postagem
CORREIOS_API_USERNAME=
CORREIOS_API_PASSWORD=
CORREIOS_POSTING_CARD=
CORREIOS_CONTRACT_NUMBER=
CORREIOS_CONTRACT_DR=
CORREIOS_ORIGIN_CEP=
CORREIOS_PAC_SERVICE_CODE=03298
CORREIOS_SEDEX_SERVICE_CODE=03220
CORREIOS_TRACKING_POLL_MINUTES=60
CORREIOS_TRACKING_SCHEDULER_MINUTES=10

# JWT Secret local (usado pelo Supabase local)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Cielo E-commerce API
# Para obter credenciais de SANDBOX:
# 1. Acesse: https://cadastrosandbox.cieloecommerce.cielo.com.br/
# 2. Crie uma conta de testes
# 3. Você receberá MerchantId e MerchantKey por email
VITE_CIELO_MERCHANT_ID=your_merchant_id
VITE_CIELO_MERCHANT_KEY=your_merchant_key
VITE_CIELO_SANDBOX=true

# =============================================
# API ASSEMED - Telemedicina
# =============================================
# Credenciais fornecidas pela Assemed para integração
# Documentação: https://dev-api-assemed.azurewebsites.net/api
VITE_ASSEMED_CLIENT_ID=your_client_id
VITE_ASSEMED_CLIENT_SECRET=your_client_secret
VITE_ASSEMED_CNPJ_CLIENT=your_cnpj

# Ambiente: true = Homologação, false = Produção
VITE_ASSEMED_SANDBOX=true

# URLs customizadas (opcional - usar apenas se precisar sobrescrever as padrão)
# VITE_ASSEMED_API_URL_HOMOLOG=https://dev-api-assemed.azurewebsites.net
# VITE_ASSEMED_APP_URL_HOMOLOG=https://dev-app-assemed.azurewebsites.net
# VITE_ASSEMED_API_URL_PROD=https://api.assemedtelemedicina.com
# VITE_ASSEMED_APP_URL_PROD=https://app.assemedtelemedicina.com

# URL do iframe white-label Novità (opcional)
# VITE_TELEMEDICINA_IFRAME_URL=https://telemedicina.novitahomecare.com.br/

# Supabase Secrets Configuration for Cielo Integration
# Copy this file to .env.supabase and fill in the values

# Cielo API 3.0 Credentials
# Get these from Cielo merchant dashboard
CIELO_MERCHANT_ID=your_merchant_id
CIELO_MERCHANT_KEY=your_merchant_key
CIELO_SANDBOX=false

# Webhook URL for Cielo (configure this in Cielo merchant dashboard)
# https://your-project.functions.supabase.co/cielo-webhook

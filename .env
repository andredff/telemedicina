# Payments (Cielo)
# In local dev, the Express proxy at localhost:5174 forwards requests to Cielo.
# In production, set VITE_PAYMENT_SERVER_URL to your deployed payment backend
# (e.g. https://api.novitahomecare.com.br). If empty, payments use mock mode.
VITE_CIELO_FORCE_MOCK="false"
VITE_USE_LOCAL_SERVER="true"
VITE_LOCAL_SERVER_URL="https://novita-telemedicina.onrender.com"

# Telemedicina (credentials must go in `.env.local` — NEVER commit secrets here)
VITE_ASSEMED_SANDBOX="true"
# VITE_ASSEMED_CLIENT_ID, VITE_ASSEMED_CLIENT_SECRET, VITE_ASSEMED_CNPJ_CLIENT
# -> set in .env.local only

# Telemedicina iFrame (White Label)
